watch_file dist/out/bazel_env-opt/bin/tools/bazel_env/bin
PATH_add dist/out/bazel_env-opt/bin/tools/bazel_env/bin
if [[ ! -d dist/out/bazel_env-opt/bin/tools/bazel_env/bin ]]; then
  log_error "ERROR[bazel_env.bzl]: Run 'bazel run //tools:bazel_env' to regenerate dist/out/bazel_env-opt/bin/tools/bazel_env/bin"
fi
