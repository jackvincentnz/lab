{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^projects/organizer/e2e/runner\\.ts$/"],
      "matchStrings": [
        "\"(?<depName>ghcr\\.io/apollographql/router):(?<currentValue>v?[^@\"]+)@(?<currentDigest>sha256:[a-f0-9]+)\""
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all non-major dependency updates",
      "groupSlug": "all-non-major-updates",
      "schedule": "* * * * 0,6",
      "matchPackageNames": ["!protobuf"]
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["confluentinc/cp-*"],
      "groupName": "confluentinc/cp-* docker images",
      "groupSlug": "confluentinc-docker-images"
    }
  ]
}
